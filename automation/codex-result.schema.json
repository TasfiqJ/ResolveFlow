{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "tests_passed",
    "summary",
    "tests",
    "blockers"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "complete",
        "blocked",
        "failed"
      ]
    },
    "tests_passed": {
      "type": "boolean"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command",
          "outcome",
          "details"
        ],
        "properties": {
          "command": {
            "type": "string"
          },
          "outcome": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "skipped"
            ]
          },
          "details": {
            "type": "string"
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
