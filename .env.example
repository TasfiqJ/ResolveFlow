# Runtime profile: snapshot, local, ci, or public.
RESOLVEFLOW_ENVIRONMENT=snapshot
RESOLVEFLOW_DATABASE_URL=postgresql+asyncpg://resolveflow:resolveflow@localhost:5432/resolveflow
RESOLVEFLOW_BUILD_ID=foundation-v1
RESOLVEFLOW_GIT_SHA=uncommitted

# Live inference is disabled and is not required for build or tests.
RESOLVEFLOW_COHERE_ALLOW_LIVE=false
RESOLVEFLOW_PUBLIC_LIVE_MODE=false

# Never add real credentials to this file. Public mode rejects connector credentials.
# RESOLVEFLOW_SLACK_SIGNING_SECRET=
# RESOLVEFLOW_JIRA_API_TOKEN=

